{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}\" mimer-session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}\" mimer-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project \"${CLAUDE_PLUGIN_ROOT}\" mimer-session-end"
          }
        ]
      }
    ]
  }
}
