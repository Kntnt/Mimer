# EditorConfig (issue #46): keep editors aligned with the CI gates. The Python
# max_line_length mirrors ruff's line-length in pyproject.toml — the single
# source of truth for it — so what an editor wraps at is what the formatter
# enforces. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
max_line_length = 100

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
# Trailing whitespace is significant in Markdown (a hard line break).
trim_trailing_whitespace = false
